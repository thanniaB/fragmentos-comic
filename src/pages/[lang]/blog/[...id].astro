---
import Layout from "@/layouts/Article.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import PrevNextButtons from "@/components/PrevNextButtons.astro"


export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => {
    const [lang, ...id] = post.id.split("/");
    return { params: { lang, id: id.join("/") || undefined }, props: post };
  });
}

const { lang } = Astro.params;
const post = Astro.props;

const { Content } = await render(post);
const title = post.data.title;

---

<Layout {title}>

  <header>
    <h1>{title}</h1>
    <time datetime={post.data.date.toISOString()}>
      {post.data.date.toLocaleDateString(lang)}
    </time>
  </header>

  {
    post.data.pages && post.data.pages.map((page) => {
      return (
          <Image src={page} alt={post.data.title} class="page" />
      )
    })
  }

  <Content class="material-icons" />

  <PrevNextButtons chapterNumber={post.data.chapterNumber}/>
  
</Layout>

<style>
  header {
    text-align: center;
    border-block-end: 1px solid var(--color-theme);
    padding-block-end: var(--sp-m);
    h1 {
      color: var(--color-theme);
      font-size: 1.8rem;
    }
  }
  .page {
    margin-bottom: var(--sp-s);
  }
</style>
