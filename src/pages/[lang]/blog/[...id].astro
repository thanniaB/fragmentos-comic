---
import Layout from "@/layouts/Article.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import PrevNextButtons from "@/components/PrevNextButtons.astro"
import { useTranslations, type Lang } from "@/i18n";
const t = useTranslations(Astro.currentLocale as Lang);


export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => {
    const [lang, ...id] = post.id.split("/");
    return { params: { lang, id: id.join("/") || undefined }, props: post };
  });
}

const { lang } = Astro.params;
const post = Astro.props;

const { Content } = await render(post);
const title = post.data.title;

---

<Layout {title}>

  <header>
    <h1>{title}</h1>
    <p class="date">
      {
        t({
          en: "Uploaded on: ",
          es: "Agregado el ",
        })
      }
      <time datetime={post.data.date.toISOString()}>      
      {post.data.date.toLocaleDateString(lang)}
    </time>
    </p>
    <PrevNextButtons chapterNumber={post.data.chapterNumber}/>
    
  </header>

  {
    post.data.pages && post.data.pages.map((page, index) => {
      return (
          <Image src={page} alt={`Image for page ${index + 1}`} class="page" />
      )
    })
  }

  <Content class="material-icons" />

  <PrevNextButtons chapterNumber={post.data.chapterNumber}/>
  
</Layout>

<style>
  header {
    text-align: center;
    border-block-end: 1px solid var(--color-accent);
    padding-block-end: var(--sp-m);
    margin-block-end: var(--sp-s);
    h1 {
      color: var(--color-theme);
      font-size: 1.8rem;
    }
  }
  .date {
    font-size: 0.8rem;
  }
  .page {
    margin-bottom: var(--sp-s);
  }
</style>
