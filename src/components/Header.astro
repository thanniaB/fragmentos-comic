---
// Header & Navigation UI displayed on each page.
import {LATEST_CHAPTER} from "@/consts";
import LocaleSelect from "@/components/i18n/LocaleSelect.astro";
import { useTranslations, type Lang } from "@/i18n";
import { getRelativeLocaleUrl } from "astro:i18n";
const t = useTranslations(Astro.currentLocale as Lang);

const locale = Astro.currentLocale as Lang;

const isActive = (path: string) =>
  getRelativeLocaleUrl(locale, path) === Astro.url.pathname;
---

<header>
  <h1 dir="ltr">
    <a href={getRelativeLocaleUrl(locale, "/")}>
      {
        t({
          en: "Thorns of a Dragon",
          es: "Fragmentos de Dragón",
        })
      }
    </a>
  </h1>

  <nav>
    <ul>
      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/blog/prologue")}
          class={isActive("/blog/prologue") ? "active" : null}
        >
          {t({ es: "Inicio", en: "Start" })}
        </a>
      </li>

      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/blog")}
          class={isActive("/blog") ? "active" : null}
        >
          {t({ es: "Capítulos", en: "Chapters" })}
        </a>
      </li>

      <li>
        <a
          href={getRelativeLocaleUrl(locale, `/blog/chapter_${LATEST_CHAPTER}`)}
          class={isActive(`/blog/chapter_${LATEST_CHAPTER}`) ? "active" : null}
        >
          {
            t({
              es: "Más Reciente",
              en: "Latest",
            })
          }
        </a>
      </li>

      <li>
        <a
          href={getRelativeLocaleUrl(locale, "/about")}
          class={isActive("/about") ? "active" : null}
        >
          {
            t({
              es: "Acerca De",
              en: "About",
            })
          }
        </a>
      </li>
    </ul>
  </nav>

  <LocaleSelect />
</header>

<style>
  header {
    display: flex;
    justify-content: space-around;
    align-items: baseline;
    padding: var(--sp-s);

    @media (width < 1100px) {
      flex-direction: column;
      align-items: center;

    }
  }

  h1 {
    font-size: 40px;
    font-family: var(--english-font);
    font-weight: 900;
    @media (width < 480px) {
      font-size: 28px;
    }
  }

  nav {
    display: flex;
    align-items: center;
    gap: var(--sp-m);
  }

  ul {
    display: flex;
    gap: var(--sp-s);
    margin-block-start: var(--sp-s);

    a {
      font-size: 1.05rem;
      display: block;
      font-weight: 600;
      letter-spacing: 0.05em;
      padding-block: 0.2em;
      padding-inline: 0.4em;
      border-radius: 4px;
      &:hover,
      &:active {
        background-color: color-mix(
          in srgb,
          var(--color-theme) 5%,
          transparent
        );
      }
      &.active {
        pointer-events: none;
        color: var(--color-theme);
      }
      .material-icons-sharp {
        opacity: 0.6;
        margin-inline-start: -0.2em;
        font-size: 0.9em;
      }
    }
  }
</style>
